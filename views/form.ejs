<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>Add Movie</h1>
    <form action="/new" method="post">
      <div class="formItem">
        <label for="name">Name</label>
        <input type="text" name="name" id="name" />
      </div>
      <div class="formItem">
        <label for="directorName">Director Name</label>
        <input type="text" name="directorName" id="directorName" />
      </div>
      <div class="formItem">
        <label for="releaseDate">Release Date</label>
        <input type="date" name="releaseDate" id="releaseDate" />
      </div>
      <div class="formItem">
        <label for="releaseDate">Runtime</label>
        <input
          type="number"
          name="runtimeHours"
          id="runtimeHours"
          min="0"
          required
        />h
        <input
          type="number"
          name="runtimeMinutes"
          id="runtimeMinutes"
          min="0"
          max="59"
          required
        />min
      </div>
      <div class="formItem">
        <label for="cast">Cast</label>
        <textarea name="cast" id="cast"></textarea>
      </div>
      <button>Submit</button>
    </form>
  </body>
</html>
