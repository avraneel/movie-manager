<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <h1>All Movies</h1>
    <ul>
    <% allMovies.forEach(item => { %>
      <li><a href="/movies/<%= item.name.toLowerCase().split(" ").join("-") %>"><%= item.name %></a></li>
    <% }); %>
    </ul>
  </body>
</html>
